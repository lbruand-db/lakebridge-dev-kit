{"version": 2, "width": 90, "height": 32, "title": "Lakebridge Reconcile \u2014 Config Generation"}
[0.0, "o", "\u001b[2m  # Lakebridge Reconcile skill demo\u001b[0m\r\n"]
[0.4, "o", "\u001b[2m  # Generating YAML config for a Snowflake \u2192 Databricks migration\u001b[0m\r\n"]
[0.8, "o", "\r\n"]
[0.8, "o", "\u001b[1;36m\u276f\u001b[0m \u001b[1;37mGenerate reconcile YAML configs for Snowflake (PROD_DB.PUBLIC)\u001b[0m\r\n"]
[0.85, "o", "  \u001b[1;37m\u2192 Databricks (main.migrated). Tables: customers, orders,\u001b[0m\r\n"]
[0.9, "o", "  \u001b[1;37morder_items, products. report_type 'all'.\u001b[0m\r\n"]
[0.95, "o", "\r\n"]
[1.95, "o", "\u001b[35m\u23fa\u001b[0m Generating reconcile.yml and recon_config.yml \u2026\r\n"]
[1.95, "o", "\r\n"]
[2.35, "o", "\u001b[2m  # reconcile.yml \u2014 source, target, and report settings\u001b[0m\r\n"]
[2.55, "o", "    \u001b[33mversion: 1\u001b[0m\r\n"]
[2.6, "o", "    \u001b[33mdata_source: snowflake\u001b[0m\r\n"]
[2.65, "o", "    \u001b[33mreport_type: all\u001b[0m\r\n"]
[2.7, "o", "    \u001b[33msecret_scope: lakebridge_snowflake\u001b[0m\r\n"]
[2.75, "o", "    \u001b[33mdatabase_config:\u001b[0m\r\n"]
[2.8, "o", "    \u001b[33m  source_schema: PUBLIC\u001b[0m\r\n"]
[2.85, "o", "    \u001b[33m  target_catalog: main\u001b[0m\r\n"]
[2.9, "o", "    \u001b[33m  target_schema: migrated\u001b[0m\r\n"]
[2.95, "o", "\r\n"]
[4.15, "o", "\u001b[2m  # recon_config.yml \u2014 per-table reconciliation rules\u001b[0m\r\n"]
[4.35, "o", "    \u001b[33mversion: 2\u001b[0m\r\n"]
[4.4, "o", "    \u001b[33mtables:\u001b[0m\r\n"]
[4.45, "o", "    \u001b[33m  - source_name: customers\u001b[0m\r\n"]
[4.5, "o", "    \u001b[33m    target_name: customers\u001b[0m\r\n"]
[4.55, "o", "    \u001b[33m    join_columns: [customer_id]\u001b[0m\r\n"]
[4.6, "o", "    \u001b[33m  - source_name: orders\u001b[0m\r\n"]
[4.65, "o", "    \u001b[33m    target_name: orders\u001b[0m\r\n"]
[4.7, "o", "    \u001b[33m    join_columns: [order_id]\u001b[0m\r\n"]
[4.75, "o", "    \u001b[33m  # \u2026 2 more table(s)\u001b[0m\r\n"]
[4.8, "o", "\r\n"]
[5.8, "o", "  \u001b[1;32m\u2713\u001b[0m \u001b[32mValid configuration generated for 4 tables\u001b[0m\r\n"]
